{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://study-chinese.local/schemas/lesson-template.schema.json",
  "title": "HSK Lesson Template",
  "type": "object",
  "required": [
    "lesson_id",
    "metadata",
    "learning_objectives",
    "vocabulary_focus",
    "grammar_focus",
    "warm_up",
    "core_modules",
    "practice",
    "review"
  ],
  "properties": {
    "lesson_id": {
      "type": "string",
      "minLength": 3,
      "maxLength": 80
    },
    "metadata": {
      "type": "object",
      "required": [
        "title_zh",
        "title_en",
        "hsk_level",
        "cefr_level",
        "primary_skill",
        "topic",
        "estimated_minutes",
        "xp_reward"
      ],
      "properties": {
        "title_zh": { "type": "string", "minLength": 1 },
        "title_en": { "type": "string", "minLength": 1 },
        "title_vi": { "type": "string" },
        "hsk_level": { "type": "integer", "minimum": 1, "maximum": 9 },
        "cefr_level": { "type": "string", "enum": ["A1", "A2", "B1", "B2", "C1", "C2"] },
        "primary_skill": {
          "type": "string",
          "enum": ["listening", "speaking", "reading", "writing", "mixed"]
        },
        "secondary_skills": {
          "type": "array",
          "items": { "type": "string", "enum": ["listening", "speaking", "reading", "writing"] },
          "uniqueItems": true,
          "default": []
        },
        "topic": { "type": "string", "minLength": 1, "maxLength": 50 },
        "estimated_minutes": { "type": "integer", "minimum": 1, "maximum": 60 },
        "xp_reward": { "type": "integer", "minimum": 1, "maximum": 300 },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      },
      "additionalProperties": true
    },
    "learning_objectives": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "learning_objectives_vi": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "vocabulary_focus": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["simplified"],
        "properties": {
          "word_id": { "type": "string" },
          "simplified": { "type": "string", "minLength": 1 },
          "pinyin": { "type": "string" },
          "english": { "type": "string" },
          "is_new": { "type": "boolean", "default": true }
        },
        "additionalProperties": true
      }
    },
    "grammar_focus": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["pattern", "examples"],
        "properties": {
          "pattern": { "type": "string", "minLength": 1 },
          "explanation": { "type": "string" },
          "explanation_vi": { "type": "string" },
          "hsk_level": { "type": "integer", "minimum": 1, "maximum": 9 },
          "cefr_level": { "type": "string", "enum": ["A1", "A2", "B1", "B2", "C1", "C2"] },
          "tips": {
            "type": "array",
            "items": { "type": "string" },
            "default": []
          },
          "tips_vi": {
            "type": "array",
            "items": { "type": "string" },
            "default": []
          },
          "examples": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "zh": { "type": "string" },
                "simplified": { "type": "string" },
                "pinyin": { "type": "string" },
                "en": { "type": "string" },
                "english": { "type": "string" },
                "vi": { "type": "string" }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    },
    "warm_up": {
      "type": "object",
      "required": ["type", "items"],
      "properties": {
        "type": { "type": "string" },
        "items": { "type": "array" }
      },
      "additionalProperties": true
    },
    "core_modules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["module_type", "phases"],
        "properties": {
          "module_type": {
            "type": "string",
            "enum": ["listening", "speaking", "reading", "writing"]
          },
          "phases": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "object" }
          }
        },
        "additionalProperties": true
      }
    },
    "practice": {
      "type": "object",
      "required": ["exercises"],
      "properties": {
        "exercises": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["kind", "prompt"],
            "properties": {
              "kind": { "type": "string" },
              "prompt": { "type": "string", "minLength": 1 },
              "prompt_vi": { "type": "string" },
              "skill": {
                "type": "string",
                "enum": ["listening", "speaking", "reading", "writing", "mixed"]
              },
              "bloom_level": {
                "type": "string",
                "enum": ["remember", "understand", "apply", "analyze", "evaluate", "create"]
              },
              "options": { "type": "array" },
              "options_vi": { "type": "array" },
              "correct_answer_vi": {},
              "explanation_vi": { "type": "string" },
              "correct_answer": {}
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "review": {
      "type": "object",
      "required": ["key_takeaways", "srs_inject_word_ids"],
      "properties": {
        "key_takeaways": {
          "type": "array",
          "items": { "type": "string" }
        },
        "srs_inject_word_ids": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
