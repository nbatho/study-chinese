{
  "name": "study-chinese-server",
  "version": "1.0.0",
  "type": "module",
  "description": "ExpressJS backend for Study Chinese application",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "lint": "node scripts/check-syntax.js",
    "db:init": "node scripts/init-db.js",
    "db:migrate": "node scripts/apply-migration.js",
    "dict:import": "node scripts/import-cc-cedict.js",
    "hsk:import": "node scripts/import-hsk-vocabulary.js",
    "lessons:import": "node scripts/import-generated-lessons.mjs",
    "lessons:generate:standard": "node scripts/generate-standard-hsk-lessons.mjs",
    "lessons:normalize-vi": "node scripts/normalize-lesson-vietnamese.mjs",
    "lessons:reset-content": "node scripts/reset-lesson-content.mjs",
    "lessons:reset-user-progress": "node scripts/reset-user-lesson-progress.mjs",
    "practice:hanzi:generate": "node scripts/generate-hanzi-practice-data.mjs",
    "content:audit": "node scripts/content-audit.mjs",
    "content:agent": "node scripts/content-agent.mjs",
    "content:import": "node scripts/content-import.mjs",
    "test": "node --test",
    "test:integration": "node --test test/integration/*.test.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pg": "^8.21.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
