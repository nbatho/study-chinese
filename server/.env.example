PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
# Optional comma-separated CORS allowlist for extra client origins.
# CLIENT_URLS=http://localhost:5174,https://your-client.example
API_BASE_URL=http://localhost:5000/api/v1

# PostgreSQL: use DATABASE_URL, or fill DB_HOST/DB_NAME/DB_USER below.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/study_chinese
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=study_chinese
# DB_USER=postgres
# DB_PASSWORD=postgres
DB_SSL=false
DB_MAX_CONNECTIONS=10
DB_IDLE_TIMEOUT_MS=30000

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN_SECONDS=604800
REFRESH_TOKEN_EXPIRES_IN_SECONDS=2592000

AI_PROVIDER=mock
# AI_PROVIDER supports: mock, gemini, openai, groq, openai-compatible.
# For gemini, set GEMINI_API_KEY or AI_API_KEY.
# For openai/openai-compatible, set OPENAI_API_KEY or AI_API_KEY.
# For groq, set GROQ_API_KEY or AI_API_KEY.
# AI_MODEL=gemini-2.5-flash
# AI_API_KEY=
# GEMINI_API_KEY=
# OPENAI_API_KEY=
# GROQ_API_KEY=
# AI_BASE_URL=
AI_TIMEOUT_MS=12000
AI_RETRY_ATTEMPTS=1
AI_RETRY_DELAY_MS=400
AI_FALLBACK_TO_MOCK=true
# In production, set AI_FALLBACK_TO_MOCK=false to surface provider errors instead of mock replies.
# Optional cost logging, USD per 1M tokens.
AI_INPUT_COST_PER_1M_TOKENS=0
AI_OUTPUT_COST_PER_1M_TOKENS=0
OCR_PROVIDER=mock
# OCR_PROVIDER supports: mock, paddle.
# Docker compose uses http://ocr:8000. Local dev can use http://localhost:8000.
OCR_BASE_URL=http://localhost:8000
# Optional shared secret for a public OCR service. Backend sends it as x-ocr-api-key.
# OCR_API_KEY=
OCR_TIMEOUT_MS=30000

TTS_PROVIDER=edge
TTS_EDGE_VOICE=zh-CN-XiaoxiaoNeural
TTS_EDGE_OUTPUT_FORMAT=audio-24khz-48kbitrate-mono-mp3
TTS_MAX_TEXT_LENGTH=300
TTS_TIMEOUT_MS=12000

STT_PROVIDER=groq
# STT_PROVIDER supports: mock, groq.
# Groq STT uses the Whisper model for speech-to-text transcription.
# Reuses GROQ_API_KEY (or AI_API_KEY) — no separate key needed.
STT_MODEL=whisper-large-v3-turbo
STT_TIMEOUT_MS=15000
